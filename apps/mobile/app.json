{
  "expo": {
    "scheme": "keywarden",
    "userInterfaceStyle": "automatic",
    "orientation": "default",
    "web": {
      "bundler": "metro"
    },
    "name": "Keywarden",
    "slug": "keywarden",
    "plugins": ["expo-font", "expo-router", "expo-secure-store", "expo-sqlite"],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "android": {
      "package": "dev.beeman.keywarden"
    }
  }
}
